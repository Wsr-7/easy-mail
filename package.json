{
  "name": "easy-mail",
  "displayName": "Easy Mail",
  "description": "Local Outlook digest collection, Copilot analysis, and dashboard for classic Outlook.",
  "version": "0.1.0",
  "publisher": "Wsr-7",
  "private": true,
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wsr-7/easy-mail.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:easyMail.pullMail",
    "onCommand:easyMail.loadMore",
    "onCommand:easyMail.generateSampleDigest",
    "onCommand:easyMail.analyze",
    "onCommand:easyMail.analyzeThread",
    "onCommand:easyMail.analyzeAllAllowed",
    "onCommand:easyMail.loadModels",
    "onCommand:easyMail.generateReports",
    "onCommand:easyMail.openDailyBrief",
    "onCommand:easyMail.openThreadReport",
    "onCommand:easyMail.openSingleMailReport",
    "onCommand:easyMail.openGuide",
    "onCommand:easyMail.openReplyTemplate",
    "onCommand:easyMail.clearLocalCache",
    "onCommand:easyMail.openWorkbench",
    "onView:easyMail.dashboard"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "scripts/**",
    "prompts/**",
    "media/**",
    "LICENSE",
    "README.md",
    "user guide.md",
    "setup.md",
    "agents.md",
    "default-config.json"
  ],
  "contributes": {
    "configuration": {
      "title": "Easy Mail",
      "properties": {
        "easyMail.rangeMode": {
          "type": "string",
          "order": 1,
          "enum": [
            "recentHours",
            "maxItems"
          ],
          "enumItemLabels": [
            "Recent Hours",
            "Max Items"
          ],
          "default": "recentHours",
          "description": "Mail pull range mode."
        },
        "easyMail.recentHours": {
          "type": "number",
          "order": 2,
          "default": 24,
          "minimum": 1,
          "description": "Pull mails received within the last N hours."
        },
        "easyMail.maxItems": {
          "type": "number",
          "order": 3,
          "default": 50,
          "minimum": 1,
          "description": "Maximum number of mails to pull."
        },
        "easyMail.folders": {
          "type": "array",
          "order": 4,
          "items": {
            "type": "string"
          },
          "default": [
            "Inbox"
          ],
          "description": "Outlook folders to scan."
        },
        "easyMail.bodyExcerptChars": {
          "type": "number",
          "order": 8,
          "default": 1500,
          "minimum": 100,
          "description": "Maximum body characters per mail sent to Copilot."
        },
        "easyMail.sampleMode": {
          "type": "boolean",
          "order": 14,
          "default": false,
          "description": "Generate sample mail data instead of reading Outlook."
        },
        "easyMail.modelFamily": {
          "type": "string",
          "order": 6,
          "enum": [
            "gpt-5.4",
            "gpt-5-mini",
            "gpt-4o-mini",
            "claude-haiku-4.5",
            "copilot-utility",
            "copilot-utility-small",
            "oswe-vscode",
            "oswe-vscode-modelD"
          ],
          "enumItemLabels": [
            "gpt-5.4",
            "gpt-5-mini",
            "gpt-4o-mini",
            "claude-haiku-4.5",
            "copilot-utility",
            "copilot-utility-small",
            "oswe-vscode",
            "oswe-vscode-modelD"
          ],
          "default": "gpt-5.4",
          "description": "Copilot model family used for analysis. The Dashboard model selector still reflects models exposed by your current VS Code session."
        },
        "easyMail.outputLanguage": {
          "type": "string",
          "order": 5,
          "enum": [
            "zh-CN",
            "en-US"
          ],
          "enumItemLabels": [
            "简体中文",
            "English"
          ],
          "default": "en-US",
          "description": "Dashboard and analysis output language."
        },
        "easyMail.analysisBatchSize": {
          "type": "number",
          "order": 9,
          "default": 5,
          "minimum": 1,
          "description": "Maximum mails analyzed by Analyze Next Batch."
        },
        "easyMail.autoAnalyzeEnabled": {
          "type": "boolean",
          "order": 10,
          "default": true,
          "description": "Allow mails under the classification threshold to be analyzed."
        },
        "easyMail.autoAnalyzeMaxClassificationLevel": {
          "type": "number",
          "order": 11,
          "enum": [
            0,
            1,
            2,
            3
          ],
          "enumItemLabels": [
            "PUBLIC",
            "INTERNAL",
            "REGISTERED",
            "HIGH REGISTERED"
          ],
          "default": 2,
          "minimum": 0,
          "maximum": 3,
          "description": "Maximum mail classification level allowed for analysis."
        },
        "easyMail.mailStoreRetentionDays": {
          "type": "number",
          "order": 15,
          "default": 1,
          "minimum": 1,
          "description": "Raw local mail queue retention days."
        },
        "easyMail.mailIndexRetentionDays": {
          "type": "number",
          "order": 16,
          "default": 7,
          "minimum": 1,
          "description": "Local de-duplication index retention days."
        },
        "easyMail.analysisRetentionDays": {
          "type": "number",
          "order": 17,
          "default": 7,
          "minimum": 1,
          "description": "Analysis summary retention days."
        },
        "easyMail.meetingDaysAhead": {
          "type": "number",
          "order": 18,
          "default": 2,
          "minimum": 1,
          "description": "Collect meetings within the next N days from Outlook calendar."
        },
        "easyMail.importantSenders": {
          "type": "array",
          "order": 12,
          "items": {
            "type": "string",
            "default": "name@example.com"
          },
          "default": [],
          "markdownDescription": "Important senders, mail groups, or keywords matched into `importantSender`. Examples: `person@example.com`, `team-alerts@company.com`, `Customer A`, `Project Phoenix`."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "easyMail",
          "title": "Dashboard",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "easyMail": [
        {
          "type": "webview",
          "id": "easyMail.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "easyMail.gettingStarted",
        "title": "Get Started with Easy Mail",
        "description": "Collect local Outlook mail, review pending items, and analyze with GitHub Copilot.",
        "steps": [
          {
            "id": "easyMail.openDashboard",
            "title": "Open the Dashboard",
            "description": "Open the Easy Mail view from the Activity Bar. Use the language button in the top-right corner to switch between English and Simplified Chinese.",
            "media": {
              "markdown": "readme.md"
            },
            "completionEvents": [
              "onView:easyMail.dashboard"
            ]
          },
          {
            "id": "easyMail.configure",
            "title": "Configure Mail Range and Model",
            "description": "Click Settings File to edit VS Code Settings. VS Code Settings are the single source of truth; the dashboard refreshes when settings change.",
            "completionEvents": [
              "onCommand:easyMail.openSettings"
            ]
          },
          {
            "id": "easyMail.fetch",
            "title": "Fetch New Mail",
            "description": "Click Fetch New to collect recent Outlook mail. After the first fetch, More History becomes available for loading older mail per folder.",
            "completionEvents": [
              "onCommand:easyMail.pullMail"
            ]
          },
          {
            "id": "easyMail.analyze",
            "title": "Analyze with Copilot",
            "description": "Choose an Analysis Model from the dashboard, then run Analyze Next Batch, Analyze Selected, or Analyze All Allowed.",
            "completionEvents": [
              "onCommand:easyMail.analyze",
              "onCommand:easyMail.analyzeAllAllowed"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "easyMail.pullMail",
        "title": "Easy Mail: Fetch New Mail"
      },
      {
        "command": "easyMail.loadMore",
        "title": "Easy Mail: More History"
      },
      {
        "command": "easyMail.generateSampleDigest",
        "title": "Easy Mail: Generate Sample Digest"
      },
      {
        "command": "easyMail.analyze",
        "title": "Easy Mail: Analyze Next Batch with Copilot"
      },
      {
        "command": "easyMail.analyzeThread",
        "title": "Easy Mail: Analyze Thread with Copilot"
      },
      {
        "command": "easyMail.analyzeAllAllowed",
        "title": "Easy Mail: Analyze All Allowed with Copilot"
      },
      {
        "command": "easyMail.loadModels",
        "title": "Easy Mail: Load Copilot Models"
      },
      {
        "command": "easyMail.refreshDashboard",
        "title": "Easy Mail: Refresh Dashboard"
      },
      {
        "command": "easyMail.openDigest",
        "title": "Easy Mail: Open Digest"
      },
      {
        "command": "easyMail.openSummary",
        "title": "Easy Mail: Open Summary"
      },
      {
        "command": "easyMail.generateReports",
        "title": "Easy Mail: Generate Reports"
      },
      {
        "command": "easyMail.openDailyBrief",
        "title": "Easy Mail: Open Daily Brief"
      },
      {
        "command": "easyMail.openThreadReport",
        "title": "Easy Mail: Open Thread Report"
      },
      {
        "command": "easyMail.openSingleMailReport",
        "title": "Easy Mail: Open Single Mail Report"
      },
      {
        "command": "easyMail.openSettings",
        "title": "Easy Mail: Open Settings"
      },
      {
        "command": "easyMail.openGuide",
        "title": "Easy Mail: Open User Guide"
      },
      {
        "command": "easyMail.openReplyTemplate",
        "title": "Easy Mail: Open Reply Template"
      },
      {
        "command": "easyMail.openPromptConfig",
        "title": "Easy Mail: Open Prompt Config"
      },
      {
        "command": "easyMail.clearLocalCache",
        "title": "Easy Mail: Clear Local Cache"
      },
      {
        "command": "easyMail.openWorkbench",
        "title": "Easy Mail: Open Workbench"
      }
    ]
  },
  "scripts": {
    "compile": "node scripts/clean-out.js && tsc -p .",
    "test": "npm run compile && node --test out/test/digest.test.js out/test/analysis-schema.test.js out/test/summary.test.js out/test/dashboard-state.test.js out/test/mail-store.test.js out/test/classification.test.js out/test/prompt-config.test.js out/test/thread-engine.test.js out/test/thread-timeline.test.js out/test/redaction.test.js out/test/security-gate.test.js out/test/thread-analysis-schema.test.js out/test/thread-prompt-builder.test.js out/test/report-single-mail.test.js out/test/report-thread.test.js out/test/report-daily.test.js out/test/llm-provider.test.js out/test/guide-webview.test.js out/test/reply-template.test.js out/test/analysis-translation.test.js out/test/html-utils.test.js out/test/config-utils.test.js out/test/dashboard-labels.test.js out/test/process-runner.test.js out/test/app-data.test.js out/test/dashboard-render.test.js out/test/message-handler.test.js out/test/sidebar-render.test.js out/test/workbench-render.test.js out/test/meeting-digest.test.js out/test/meeting-store.test.js",
    "package:vsix": "npm run compile && vsce package --out releases/easy-mail-0.1.0.vsix",
    "package:vsix:dev": "node scripts/package-dev-vsix.js",
    "validate:sample": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-sample-validation.ps1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.3"
  }
}

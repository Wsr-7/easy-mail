{
  "name": "email-analysis-poc",
  "displayName": "Email Analysis POC",
  "description": "Local Outlook digest collection, Copilot analysis, and dashboard for classic Outlook.",
  "version": "0.1.0",
  "publisher": "Wsr-7",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Wsr-7/email-analysis.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:emailAnalysis.pullMail",
    "onCommand:emailAnalysis.loadMore",
    "onCommand:emailAnalysis.generateSampleDigest",
    "onCommand:emailAnalysis.analyze",
    "onCommand:emailAnalysis.analyzeThread",
    "onCommand:emailAnalysis.analyzeAllAllowed",
    "onCommand:emailAnalysis.generateReports",
    "onCommand:emailAnalysis.openDailyBrief",
    "onCommand:emailAnalysis.openThreadReport",
    "onCommand:emailAnalysis.openSingleMailReport",
    "onCommand:emailAnalysis.clearLocalCache",
    "onView:emailAnalysis.dashboard"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "scripts/**",
    "prompts/**",
    "media/**",
    "LICENSE",
    "README.md",
    "user guide.md",
    "setup.md",
    "agents.md",
    "default-config.json"
  ],
  "contributes": {
    "configuration": {
      "title": "Email Analysis",
      "properties": {
        "emailAnalysis.rangeMode": {
          "type": "string",
          "order": 1,
          "enum": [
            "recentHours",
            "maxItems"
          ],
          "enumItemLabels": [
            "Recent Hours",
            "Max Items"
          ],
          "default": "recentHours",
          "description": "Mail pull range mode."
        },
        "emailAnalysis.recentHours": {
          "type": "number",
          "order": 2,
          "default": 24,
          "minimum": 1,
          "description": "Pull mails received within the last N hours."
        },
        "emailAnalysis.maxItems": {
          "type": "number",
          "order": 3,
          "default": 50,
          "minimum": 1,
          "description": "Maximum number of mails to pull."
        },
        "emailAnalysis.folders": {
          "type": "array",
          "order": 4,
          "items": {
            "type": "string"
          },
          "default": [
            "Inbox"
          ],
          "description": "Outlook folders to scan."
        },
        "emailAnalysis.bodyExcerptChars": {
          "type": "number",
          "order": 8,
          "default": 1500,
          "minimum": 100,
          "description": "Maximum body characters per mail sent to Copilot."
        },
        "emailAnalysis.sampleMode": {
          "type": "boolean",
          "order": 14,
          "default": false,
          "description": "Generate sample mail data instead of reading Outlook."
        },
        "emailAnalysis.modelFamily": {
          "type": "string",
          "order": 6,
          "enum": [
            "gpt-5.4",
            "gpt-5-mini",
            "gpt-4o-mini",
            "claude-haiku-4.5",
            "copilot-utility",
            "copilot-utility-small",
            "oswe-vscode",
            "oswe-vscode-modelD"
          ],
          "enumItemLabels": [
            "gpt-5.4",
            "gpt-5-mini",
            "gpt-4o-mini",
            "claude-haiku-4.5",
            "copilot-utility",
            "copilot-utility-small",
            "oswe-vscode",
            "oswe-vscode-modelD"
          ],
          "default": "gpt-5.4",
          "description": "Copilot model family used for analysis. The Dashboard model selector still reflects models exposed by your current VS Code session."
        },
        "emailAnalysis.outputLanguage": {
          "type": "string",
          "order": 5,
          "enum": [
            "zh-CN",
            "en-US"
          ],
          "enumItemLabels": [
            "简体中文",
            "English"
          ],
          "default": "en-US",
          "description": "Dashboard and analysis output language."
        },
        "emailAnalysis.analysisBatchSize": {
          "type": "number",
          "order": 9,
          "default": 5,
          "minimum": 1,
          "description": "Maximum mails analyzed by Analyze Next Batch."
        },
        "emailAnalysis.autoAnalyzeEnabled": {
          "type": "boolean",
          "order": 10,
          "default": true,
          "description": "Allow mails under the classification threshold to be analyzed automatically."
        },
        "emailAnalysis.autoAnalyzeMaxClassificationLevel": {
          "type": "number",
          "order": 11,
          "enum": [
            0,
            1,
            2,
            3
          ],
          "enumItemLabels": [
            "PUBLIC",
            "INTERNAL",
            "REGISTERED",
            "HIGH REGISTERED"
          ],
          "default": 2,
          "minimum": 0,
          "maximum": 3,
          "description": "Maximum mail classification allowed for automatic analysis."
        },
        "emailAnalysis.mailStoreRetentionDays": {
          "type": "number",
          "order": 15,
          "default": 1,
          "minimum": 1,
          "description": "Raw local mail queue retention days."
        },
        "emailAnalysis.mailIndexRetentionDays": {
          "type": "number",
          "order": 16,
          "default": 7,
          "minimum": 1,
          "description": "Local de-duplication index retention days."
        },
        "emailAnalysis.analysisRetentionDays": {
          "type": "number",
          "order": 17,
          "default": 7,
          "minimum": 1,
          "description": "Analysis summary retention days."
        },
        "emailAnalysis.importantSenders": {
          "type": "array",
          "order": 12,
          "items": {
            "type": "string",
            "default": "name@example.com"
          },
          "default": [],
          "markdownDescription": "Important senders, mail groups, or keywords matched into `importantSender`. Examples: `person@example.com`, `team-alerts@company.com`, `Customer A`, `Project Phoenix`."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "emailAnalysis",
          "title": "Email Analysis",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "emailAnalysis": [
        {
          "type": "webview",
          "id": "emailAnalysis.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "emailAnalysis.gettingStarted",
        "title": "Get Started with Email Analysis",
        "description": "Collect local Outlook mail, review pending items, and analyze with GitHub Copilot.",
        "steps": [
          {
            "id": "emailAnalysis.openDashboard",
            "title": "Open the Dashboard",
            "description": "Open the Email Analysis view from the Activity Bar. Use the language button in the top-right corner to switch between English and Simplified Chinese.",
            "media": {
              "markdown": "readme.md"
            },
            "completionEvents": [
              "onView:emailAnalysis.dashboard"
            ]
          },
          {
            "id": "emailAnalysis.configure",
            "title": "Configure Mail Range and Model",
            "description": "Click Settings File to edit VS Code Settings. VS Code Settings are the single source of truth; the dashboard refreshes when settings change.",
            "completionEvents": [
              "onCommand:emailAnalysis.openSettings"
            ]
          },
          {
            "id": "emailAnalysis.fetch",
            "title": "Fetch New Mail",
            "description": "Click Fetch New to collect recent Outlook mail. After the first fetch, More History becomes available for loading older mail per folder.",
            "completionEvents": [
              "onCommand:emailAnalysis.pullMail"
            ]
          },
          {
            "id": "emailAnalysis.analyze",
            "title": "Analyze with Copilot",
            "description": "Choose an Analysis Model from the dashboard, then run Analyze Next Batch, Analyze Selected, or Analyze All Allowed.",
            "completionEvents": [
              "onCommand:emailAnalysis.analyze",
              "onCommand:emailAnalysis.analyzeAllAllowed"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "emailAnalysis.pullMail",
        "title": "Email Analysis: Fetch New Mail"
      },
      {
        "command": "emailAnalysis.loadMore",
        "title": "Email Analysis: More History"
      },
      {
        "command": "emailAnalysis.generateSampleDigest",
        "title": "Email Analysis: Generate Sample Digest"
      },
      {
        "command": "emailAnalysis.analyze",
        "title": "Email Analysis: Analyze Next Batch with Copilot"
      },
      {
        "command": "emailAnalysis.analyzeThread",
        "title": "Email Analysis: Analyze Thread with Copilot"
      },
      {
        "command": "emailAnalysis.analyzeAllAllowed",
        "title": "Email Analysis: Analyze All Allowed with Copilot"
      },
      {
        "command": "emailAnalysis.refreshDashboard",
        "title": "Email Analysis: Refresh Dashboard"
      },
      {
        "command": "emailAnalysis.openDigest",
        "title": "Email Analysis: Open Digest"
      },
      {
        "command": "emailAnalysis.openSummary",
        "title": "Email Analysis: Open Summary"
      },
      {
        "command": "emailAnalysis.generateReports",
        "title": "Email Analysis: Generate Reports"
      },
      {
        "command": "emailAnalysis.openDailyBrief",
        "title": "Email Analysis: Open Daily Brief"
      },
      {
        "command": "emailAnalysis.openThreadReport",
        "title": "Email Analysis: Open Thread Report"
      },
      {
        "command": "emailAnalysis.openSingleMailReport",
        "title": "Email Analysis: Open Single Mail Report"
      },
      {
        "command": "emailAnalysis.openSettings",
        "title": "Email Analysis: Open Settings"
      },
      {
        "command": "emailAnalysis.openPromptConfig",
        "title": "Email Analysis: Open Prompt Config"
      },
      {
        "command": "emailAnalysis.clearLocalCache",
        "title": "Email Analysis: Clear Local Cache"
      }
    ]
  },
  "scripts": {
    "compile": "node scripts/clean-out.js && tsc -p .",
    "test": "npm run compile && node --test out/test/digest.test.js out/test/analysis-schema.test.js out/test/summary.test.js out/test/dashboard-state.test.js out/test/mail-store.test.js out/test/classification.test.js out/test/prompt-config.test.js out/test/thread-engine.test.js out/test/thread-timeline.test.js out/test/redaction.test.js out/test/security-gate.test.js out/test/thread-analysis-schema.test.js out/test/thread-prompt-builder.test.js out/test/report-single-mail.test.js out/test/report-thread.test.js out/test/report-daily.test.js out/test/llm-provider.test.js",
    "package:vsix": "npm run compile && vsce package --out releases/email-analysis-poc-0.1.0.vsix",
    "package:vsix:dev": "node scripts/package-dev-vsix.js",
    "validate:sample": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-sample-validation.ps1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
